# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google AI Studio (Gemini)
VITE_GEMINI_API_KEY=your-gemini-api-key

# Divine Pride (https://www.divine-pride.net/)
# Crie uma conta em divine-pride.net, vá no seu perfil e gere uma API Key gratuita.
#
# DIVINE_PRIDE_API_KEY  → usada pela Vercel Function (api/skill-tree.ts)
#                         Configure no painel da Vercel: Settings > Environment Variables
#
# VITE_DIVINE_PRIDE_KEY → exposta ao browser (se precisar chamar a API direto do front)
#                         Adicione no .env.local com o mesmo valor.
DIVINE_PRIDE_API_KEY=your-divine-pride-api-key
VITE_DIVINE_PRIDE_KEY=your-divine-pride-api-key
